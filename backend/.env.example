# Скопіюйте цей файл у .env і заповніть реальними значеннями перед деплоєм.

# Локально можна лишити SQLite (за замовчуванням). На Render підставте Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Дані для першого входу в адмінку (замовниця зможе змінити пароль пізніше,
# коли з'явиться відповідний функціонал — поки міняється тільки через .env)
ADMIN_EMAIL=dina@dinastyleknits.com
ADMIN_PASSWORD=change-me-please

# Обов'язково згенерувати випадковий рядок перед деплоєм на прод, наприклад:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-in-production

# На проді — конкретний домен фронтенду (напр. https://dinastyleknits-shop.vercel.app)
ALLOWED_ORIGINS=*
